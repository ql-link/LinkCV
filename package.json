{
  "name": "markdown-resume-generator",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite --host 127.0.0.1",
    "dev:api": "node server/index.mjs",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "start": "NODE_ENV=production node server/index.mjs"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@uiw/react-codemirror": "^4.25.10",
    "@vitejs/plugin-react": "5.0.4",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "concurrently": "^10.0.3",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.21.0",
    "markdown-it": "^14.2.0",
    "minio": "^8.0.7",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "vite": "6.4.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3"
  }
}
